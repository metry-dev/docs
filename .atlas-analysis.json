  "keyFeatures": [
    "Browser-native event tracking with automatic batching and retry",
    "User identification with traits for personalized analytics",
    "Funnel step tracking via Metry.step()",
    "Automatic page-unload flushing via sendBeacon",
    "Configurable flush intervals and batch sizes",
    "Safe for SSR/Next.js — no-ops on server, client-only execution",
    "Debug mode for development logging"
  ],
  "publicApiSurface": [
    "Metry.init(config)",
    "Metry.identify(userId, traits)",
    "Metry.step(name, properties)",
    "Metry.flush()",
    "Metry.sendBeacon()",
    "Metry.reset()",
